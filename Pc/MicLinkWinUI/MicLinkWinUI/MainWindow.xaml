<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MicLinkWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MicLinkWinUI.Presentation.ViewModels"
    xmlns:controls="using:MicLinkWinUI.Presentation.Controls"
    Title="MicLink">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid Background="{ThemeResource SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Status bar -->
        <Border Grid.Row="0" Background="{ThemeResource CardBackgroundBrush}"
                BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,0,24,0">
                    <FontIcon Glyph="&#xE717;" FontSize="22" Foreground="{ThemeResource PrimaryTextBrush}" />
                    <TextBlock Text="MicLink" FontSize="18" FontWeight="SemiBold"
                               Foreground="{ThemeResource PrimaryTextBrush}" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" FontWeight="SemiBold" />
                    <TextBlock Text="{x:Bind ViewModel.Telemetry.DeviceName, Mode=OneWay}"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="2" Width="72" Margin="8,0,0,0" Spacing="2">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="ЗАРЯД" />
                    <TextBlock Style="{StaticResource MetricValueStyle}" FontSize="14"
                               Text="{x:Bind ViewModel.BatteryDisplay, Mode=OneWay}" />
                </StackPanel>
                <StackPanel Grid.Column="3" Width="72" Margin="8,0,0,0" Spacing="2">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="СИГНАЛ" />
                    <TextBlock Style="{StaticResource MetricValueStyle}" FontSize="14"
                               Text="{x:Bind ViewModel.SignalDisplay, Mode=OneWay}" />
                </StackPanel>
                <StackPanel Grid.Column="4" Width="110" Margin="8,0,0,0" Spacing="4">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="МИКРОФОН" />
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource MetricValueStyle}" FontSize="14"
                                   Text="{x:Bind ViewModel.MicStatusDisplay, Mode=OneWay}" />
                        <ToggleButton x:Name="MicMuteButton" Width="32" Height="32" Padding="0"
                                      IsEnabled="{x:Bind ViewModel.CanControlMute, Mode=OneWay}"
                                      IsChecked="{x:Bind ViewModel.IsMicrophoneMuted, Mode=OneWay}"
                                      Click="MicMuteButton_Click"
                                      ToolTipService.ToolTip="Вкл/выкл микрофон">
                            <FontIcon x:Name="MicMuteIcon" Glyph="&#xE720;" FontSize="14" />
                        </ToggleButton>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="5" Width="72" Margin="8,0,0,0" Spacing="2">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="ПИНГ" />
                    <TextBlock Style="{StaticResource MetricValueStyle}" FontSize="14"
                               Text="{x:Bind ViewModel.PingDisplay, Mode=OneWay}" />
                </StackPanel>
                <StackPanel Grid.Column="6" Width="90" Margin="8,0,0,0" Spacing="2"
                            Visibility="{x:Bind ViewModel.PairingPinVisibility, Mode=OneWay}">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="PIN" />
                    <TextBlock Style="{StaticResource MetricValueStyle}" FontSize="14"
                               Text="{x:Bind ViewModel.PairingPinDisplay, Mode=OneWay}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main shell -->
        <NavigationView Grid.Row="1" x:Name="MainNav"
                        PaneDisplayMode="Left" IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False" SelectionChanged="MainNav_SelectionChanged"
                        Background="{ThemeResource SurfaceBrush}">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Микрофон" Tag="mic" Icon="Microphone" />
                <NavigationViewItem Content="Цепочка эффектов" Tag="fx">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Switch" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Камера" Tag="cam" Icon="Camera" />
                <NavigationViewItem Content="Настройки" Tag="settings" Icon="Setting" />
                <NavigationViewItem Content="Журнал" Tag="logs" Icon="Document" />
            </NavigationView.MenuItems>

            <Grid Padding="20,12,20,20">
                <!-- Microphone -->
                <ScrollViewer x:Name="SectionMic" Visibility="Visible" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" MaxWidth="640">
                        <TextBlock Text="Микрофон" FontSize="22" FontWeight="SemiBold" />
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="УРОВЕНЬ ВХОДА" />
                                <ProgressBar Value="{x:Bind ViewModel.AudioInputLevel, Mode=OneWay}"
                                             Maximum="100" Height="10" />
                                <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                                           Text="{x:Bind ViewModel.AudioLevelHint, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Height="160" Padding="12">
                            <controls:SpectrumVisualizer x:Name="MicSpectrum"
                                                         InputLevel="{x:Bind ViewModel.AudioInputLevel, Mode=OneWay}"
                                                         IsVisualizationEnabled="{x:Bind ViewModel.IsSpectrumVisualizerEnabled, Mode=OneWay}"
                                                         ToggleRequested="MicSpectrum_ToggleRequested" />
                        </Border>
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" TextWrapping="WrapWholeWords"
                                   Text="Сигнал с телефона проходит через цепочку эффектов и попадает в виртуальный микрофон Windows." />
                    </StackPanel>
                </ScrollViewer>

                <!-- Effects chain -->
                <Grid x:Name="SectionFx" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Цепочка эффектов" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" TextWrapping="WrapWholeWords"
                                       Text="Перетаскивай блоки в цепочке. Добавляй встроенные эффекты или VST из библиотеки." />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Content="Пресет: Discord"
                                    Command="{x:Bind EffectsChainViewModel.ApplyVoicePresetCommand}" />
                            <Button Content="Обновить VST"
                                    Command="{x:Bind EffectsChainViewModel.RefreshVstLibraryCommand}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>

                        <!-- Library -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="БИБЛИОТЕКА" />
                                <TextBlock Grid.Row="1" Margin="0,8,0,4" FontWeight="SemiBold" Text="Встроенные" />
                                <ListView Grid.Row="2" ItemsSource="{x:Bind EffectsChainViewModel.BuiltInLibrary, Mode=OneWay}"
                                          SelectionMode="None" IsItemClickEnabled="True"
                                          ItemClick="BuiltInLibrary_ItemClick">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:EffectLibraryItemViewModel">
                                            <Grid Padding="4,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{x:Bind Category}" FontSize="11"
                                                               Foreground="{StaticResource MutedTextBrush}" />
                                                </StackPanel>
                                                <FontIcon Grid.Column="1" Glyph="&#xE710;" FontSize="12"
                                                          Foreground="{StaticResource MutedTextBrush}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock Grid.Row="3" Margin="0,12,0,4" FontWeight="SemiBold" Text="VST плагины" />
                                <Grid Grid.Row="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBox PlaceholderText="Поиск VST…"
                                             Text="{x:Bind EffectsChainViewModel.VstSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ListView Grid.Row="1" Margin="0,8,0,0"
                                              ItemsSource="{x:Bind EffectsChainViewModel.VstLibrary, Mode=OneWay}"
                                              SelectionMode="None" IsItemClickEnabled="True"
                                              ItemClick="VstLibrary_ItemClick">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:EffectLibraryItemViewModel">
                                                <StackPanel Padding="4,6" Spacing="2">
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{x:Bind Category}" FontSize="11"
                                                               Foreground="{StaticResource MutedTextBrush}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Chain -->
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="СИГНАЛ → OUT" />
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,8">
                                    <Border Background="{ThemeResource CardBorderBrush}" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="IN" FontWeight="SemiBold" FontSize="12" />
                                    </Border>
                                    <FontIcon Glyph="&#xE76C;" Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                    <ListView x:Name="ChainList"
                                              ItemsSource="{x:Bind EffectsChainViewModel.Chain, Mode=OneWay}"
                                              SelectedItem="{x:Bind EffectsChainViewModel.SelectedSlot, Mode=TwoWay}"
                                              SelectionMode="Single"
                                              CanDragItems="True"
                                              CanReorderItems="True"
                                              AllowDrop="True"
                                              DragItemsStarting="ChainList_DragItemsStarting"
                                              DragItemsCompleted="ChainList_DragItemsCompleted"
                                              ContainerContentChanging="ChainList_ContainerContentChanging">
                                        <ListView.ItemContainerTransitions>
                                            <TransitionCollection>
                                                <AddDeleteThemeTransition />
                                            </TransitionCollection>
                                        </ListView.ItemContainerTransitions>
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0,0,0,8" />
                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:EffectSlotViewModel">
                                                <Border Style="{StaticResource ChainSlotStyle}" Margin="0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon Glyph="&#xE700;" Margin="0,0,8,0"
                                                                  Foreground="{StaticResource MutedTextBrush}" />
                                                        <StackPanel Grid.Column="1" Spacing="2">
                                                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                                            <TextBlock FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                                                       Text="{x:Bind StatusLabel}" />
                                                        </StackPanel>
                                                        <ToggleSwitch Grid.Column="2" IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                                                      OffContent="" OnContent="" MinWidth="0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </ScrollViewer>
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                                    <FontIcon Glyph="&#xE76C;" Foreground="{StaticResource MutedTextBrush}" />
                                    <Border Background="{ThemeResource CardBorderBrush}" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="OUT → Discord" FontWeight="SemiBold" FontSize="12" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Parameters -->
                        <Border Grid.Column="2" x:Name="FxParamsCard" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="ПАРАМЕТРЫ" />
                                <StackPanel x:Name="FxParamsToolbar" Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,12">
                                    <Button Content="↑" Command="{x:Bind EffectsChainViewModel.MoveSelectedUpCommand}" />
                                    <Button Content="↓" Command="{x:Bind EffectsChainViewModel.MoveSelectedDownCommand}" />
                                    <Button Content="Удалить" Command="{x:Bind EffectsChainViewModel.RemoveSelectedCommand}" />
                                </StackPanel>
                                <ScrollViewer x:Name="FxParamsContent" Grid.Row="2">
                                    <StackPanel Spacing="12">
                                        <ItemsControl ItemsSource="{x:Bind EffectsChainViewModel.SelectedSlot.Parameters, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:EffectParameterViewModel">
                                                    <StackPanel Spacing="4" Margin="0,0,0,12">
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Text="{x:Bind Label, Mode=OneWay}" />
                                                        <TextBlock Foreground="{StaticResource MutedTextBrush}">
                                                            <Run Text="{x:Bind ValueDisplay, Mode=OneWay}" />
                                                            <Run Text=" " />
                                                            <Run Text="{x:Bind Unit, Mode=OneWay}" />
                                                        </TextBlock>
                                                        <Slider Minimum="{x:Bind Min}" Maximum="{x:Bind Max}"
                                                                Value="{x:Bind Value, Mode=TwoWay}" StepFrequency="0.1" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Foreground="{StaticResource MutedTextBrush}" TextWrapping="WrapWholeWords"
                                                   Visibility="{x:Bind EffectsChainViewModel.SelectedSlotIsVst, Mode=OneWay}"
                                                   Text="VST добавлен в цепочку. Обработка через VST host будет в следующей версии — сейчас pass-through." />
                                    </StackPanel>
                                </ScrollViewer>

                                <Border x:Name="FxParamsDragOverlay" Grid.RowSpan="3"
                                        Visibility="Collapsed" AllowDrop="True"
                                        CornerRadius="12"
                                        Background="#D9121218"
                                        BorderThickness="3"
                                        BorderBrush="#66E74C3C"
                                        DragOver="FxParamsDragOverlay_DragOver"
                                        DragLeave="FxParamsDragOverlay_DragLeave"
                                        Drop="FxParamsDragOverlay_Drop">
                                    <Grid>
                                        <Canvas x:Name="FxDragNoiseCanvas" IsHitTestVisible="False" Opacity="0.35" />
                                        <Border IsHitTestVisible="False"
                                                BorderThickness="1"
                                                BorderBrush="#44FF6B6B"
                                                CornerRadius="10"
                                                Margin="6" />
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="14">
                                            <FontIcon x:Name="FxDeleteIcon" Glyph="&#xE74D;" FontSize="42" Foreground="#FFE74C3C" />
                                            <TextBlock x:Name="FxDeleteHint"
                                                       Text="Отпустите — удалить эффект"
                                                       Foreground="#FFFF8A80"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       TextWrapping="WrapWholeWords"
                                                       TextAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Camera -->
                <ScrollViewer x:Name="SectionCam" Visibility="Collapsed">
                    <StackPanel Spacing="16" MaxWidth="640">
                        <TextBlock Text="Камера" FontSize="22" FontWeight="SemiBold" />
                        <Border Style="{StaticResource CardStyle}" Height="220">
                            <FontIcon Glyph="&#xE714;" FontSize="48"
                                      Foreground="{StaticResource MutedTextBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="В разработке." />
                    </StackPanel>
                </ScrollViewer>

                <!-- Settings -->
                <ScrollViewer x:Name="SectionSettings" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="20" MaxWidth="520">
                        <TextBlock Text="Настройки" FontSize="22" FontWeight="SemiBold" />
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="ТЕМА" />
                            <RadioButtons x:Name="ThemeRadioButtons" SelectedIndex="1"
                                          SelectionChanged="ThemeRadio_SelectionChanged">
                                <RadioButton Content="Системная" Tag="System" />
                                <RadioButton Content="Тёмная" Tag="Dark" />
                                <RadioButton Content="Светлая" Tag="Light" />
                            </RadioButtons>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="МИКРОФОН" />
                            <TextBlock Text="{x:Bind SettingsViewModel.DriverStatusText, Mode=OneWay}" FontWeight="SemiBold" />
                            <Button Content="Установить драйвер"
                                    Command="{x:Bind SettingsViewModel.InstallDriverCommand}"
                                    Visibility="{x:Bind SettingsViewModel.InstallButtonVisibility, Mode=OneWay}" />
                            <ProgressRing IsActive="{x:Bind SettingsViewModel.IsInstallingDriver, Mode=OneWay}"
                                          Width="28" Height="28"
                                          Visibility="{x:Bind SettingsViewModel.InstallingVisibility, Mode=OneWay}" />
                            <ToggleSwitch Header="Монитор на колонках"
                                          IsOn="{x:Bind SettingsViewModel.MonitorOnSpeakers, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="ГОРЯЧИЕ КЛАВИШИ" />
                            <TextBox Header="Микрофон (mute)" IsReadOnly="True"
                                     Text="{x:Bind SettingsViewModel.HotkeyMicMute, Mode=OneWay}" />
                            <TextBox Header="Камера (mute)" IsReadOnly="True"
                                     Text="{x:Bind SettingsViewModel.HotkeyCameraMute, Mode=OneWay}" />
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="WrapWholeWords"
                                       Text="Назначение клавиш будет добавлено позже. Состояние mute синхронизируется с телефоном." />
                        </StackPanel>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="ВИРТУАЛЬНЫЕ УСТРОЙСТВА" />
                                <TextBlock Text="{x:Bind MicDeviceName, Mode=OneWay}" />
                                <TextBlock Text="{x:Bind CameraDeviceName, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Logs -->
                <Grid x:Name="SectionLogs" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Журнал" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="12">
                        <ScrollViewer>
                            <TextBlock FontFamily="Consolas" FontSize="12"
                                       Text="{x:Bind LogsViewModel.LogText, Mode=OneWay}"
                                       TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
