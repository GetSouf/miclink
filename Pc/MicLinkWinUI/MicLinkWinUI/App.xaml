<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="MicLinkWinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MicLinkWinUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="SurfaceBrush" Color="#F5F6FA" />
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#DCDEE9" />
                    <SolidColorBrush x:Key="MutedTextBrush" Color="#646880" />
                    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1E202C" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="SurfaceBrush" Color="#16161F" />
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E1E2E" />
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#2D2D44" />
                    <SolidColorBrush x:Key="MutedTextBrush" Color="#A0A0B8" />
                    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F5F5FA" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <SolidColorBrush x:Key="AccentBrush" Color="#6C5CE7" />

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource MutedTextBrush}" />
            </Style>

            <Style x:Key="MetricValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
