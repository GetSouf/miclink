<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MicLinkWinUI.Presentation.Controls.SpectrumVisualizer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="Transparent" PointerPressed="RootGrid_PointerPressed">
        <Canvas x:Name="BarsCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        <Border x:Name="DisabledOverlay" Background="#AA16161F" CornerRadius="12"
                Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                <FontIcon Glyph="&#xE767;" FontSize="28" Foreground="{StaticResource MutedTextBrush}" />
                <TextBlock Text="Визуализация выключена" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
